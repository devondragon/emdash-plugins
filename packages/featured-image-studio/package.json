{
  "name": "@devondragon/emdash-plugin-featured-image-studio",
  "version": "0.1.0",
  "description": "EmDash plugin: unified featured-image picker with stock photo search (Unsplash) and field-widget editor integration. AI generation planned for v0.2.",
  "license": "MIT",
  "author": "Devon Hillard <devon@devondragon.com>",
  "homepage": "https://github.com/devondragon/emdash-plugins/tree/main/packages/featured-image-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devondragon/emdash-plugins.git",
    "directory": "packages/featured-image-studio"
  },
  "bugs": "https://github.com/devondragon/emdash-plugins/issues",
  "keywords": [
    "emdash",
    "emdash-plugin",
    "cms",
    "images",
    "unsplash",
    "media",
    "featured-image"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
