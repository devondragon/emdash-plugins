    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "emdash": "^0.1.0",
    "react": "^19.0.0",
    "@cloudflare/kumo": "^1.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/kumo": "^1.17.0",
    "@phosphor-icons/react": "^2.1.10",
    "@types/react": "^19.2.14",
    "emdash": "^0.1.0",
    "react": "^19.2.4",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.0.0"
  }
}
